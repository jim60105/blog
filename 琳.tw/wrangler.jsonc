{
  "name": "blog",
  "compatibility_date": "2025-06-01",
  "build": {
    "command": "zola build"
  },
  "assets": {
    "directory": "./public/",
    "not_found_handling": "404-page"
  },
  "env": {
    "pr": {
      "build": {
        "command": "zola build --base-url https://blog-pr-${PR_NUMBER}.jim60105.workers.dev"
      }
    }
  }
}
